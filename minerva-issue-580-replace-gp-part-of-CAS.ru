PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX dc: <http://purl.org/dc/elements/1.1/>
PREFIX lego: <http://geneontology.org/lego/>
PREFIX obo: <http://purl.obolibrary.org/obo/>
PREFIX occurs_in: <http://purl.obolibrary.org/obo/BFO_0000066>
PREFIX part_of: <http://purl.obolibrary.org/obo/BFO_0000050>
PREFIX located_in: <http://purl.obolibrary.org/obo/RO_0001025>
PREFIX enabled_by: <http://purl.obolibrary.org/obo/RO_0002333>
PREFIX GO: <http://purl.obolibrary.org/obo/GO_>
DELETE {
  GRAPH ?model {
    ?gp_or_complex part_of: ?cae .
    ?axiom owl:annotatedProperty part_of: .
  }
}
INSERT {
  GRAPH ?model {
    ?gp_or_complex located_in: ?cae .
    ?axiom owl:annotatedProperty located_in: .
  }
}
WHERE {
  GRAPH ?model {
    ?gp_or_complex part_of: ?cae .
    ?gp_or_complex rdf:type ?gp_or_complex_type .
    ?axiom rdf:type owl:Axiom ;
        owl:annotatedSource ?gp_or_complex ;
        owl:annotatedProperty part_of: ;
        owl:annotatedTarget ?cae .
    FILTER(?gp_or_complex_type != owl:NamedIndividual)
    FILTER(!STRSTARTS(STR(?gp_or_complex_type), "http://purl.obolibrary.org/obo/"))
    ?cae rdf:type ?cae_type .
    VALUES ?cae_type {
