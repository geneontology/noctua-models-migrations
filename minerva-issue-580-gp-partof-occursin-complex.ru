PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX dc: <http://purl.org/dc/elements/1.1/>
PREFIX lego: <http://geneontology.org/lego/>
PREFIX obo: <http://purl.obolibrary.org/obo/>
PREFIX occurs_in: <http://purl.obolibrary.org/obo/BFO_0000066>
PREFIX part_of: <http://purl.obolibrary.org/obo/BFO_0000050>
PREFIX enabled_by: <http://purl.obolibrary.org/obo/RO_0002333>
PREFIX GO: <http://purl.obolibrary.org/obo/GO_>
PREFIX hint: <http://www.bigdata.com/queryHints#>

DELETE {
  GRAPH ?model {
    ?mf occurs_in: ?complex .
    ?axiom owl:annotatedSource ?mf .
    ?axiom owl:annotatedProperty occurs_in: .
  }
}
INSERT {
  GRAPH ?model {
    ?gp part_of: ?complex .
    ?axiom owl:annotatedSource ?gp .
    ?axiom owl:annotatedProperty part_of: .
  }
}
WHERE {
    # We need to select for models where only one ?gp is going to be connected to the complex
    # Othewise we will create invalid OWL
    {
    SELECT ?mf ?complex (MIN(?_gp) AS ?gp) ?model
    WHERE {
      GRAPH ?model {
        ?mf occurs_in: ?complex .
        ?mf enabled_by: ?_gp .
        ?complex rdf:type ?complex_type .
        VALUES ?complex_type {
